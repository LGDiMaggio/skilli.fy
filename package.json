{
  "name": "skillify",
  "version": "0.1.0",
  "description": "Convert real workflows into Claude Skills — record, extract, generate, validate.",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "clean": "npm run clean --workspaces --if-present",
    "lint": "eslint packages/cli/src packages/core/src packages/mcp/src packages/recorder/src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --build tsconfig.json"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/LGDiMaggio/skilli.fy"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "tsup": "^8.0.0"
  }
}
